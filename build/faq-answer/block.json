{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "blockparty/faq-answer",
  "version": "2.0.3",
  "title": "FAQ Answer",
  "category": "design",
  "parent": [
    "blockparty/faq-item"
  ],
  "description": "Content of the FAQ answer.",
  "supports": {
    "html": false,
    "inserter": false,
    "reusable": false,
    "spacing": {
      "margin": true,
      "padding": true,
      "blockGap": true
    }
  },
  "attributes": {
    "isAccordion": {
      "type": "boolean",
      "default": true
    }
  },
  "textdomain": "blockparty-faq",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css"
}