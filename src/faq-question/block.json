{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "blockparty/faq-question",
	"version": "1.0.2",
	"title": "FAQ Question",
	"category": "design",
	"parent": [ "blockparty/faq-item" ],
	"description": "A question in a FAQ list",
	"supports": {
		"html": false,
		"inserter": false,
		"reusable": false
	},
	"attributes": {
		"question": {
			"type": "string",
			"default": ""
		},
		"isAccordion": {
			"type": "boolean",
			"default": true
		}
	},
	"textdomain": "blockparty-faq"
}
